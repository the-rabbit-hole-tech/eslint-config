{
  "name": "@the-rabbit-hole/eslint-config",
  "version": "0.1.0",
  "description": "A eslint config designed for @the-rabbit-hole projects, but can be used publicly.",
  "keywords": [
    "eslint",
    "eslint-config"
  ],
  "homepage": "https://github.com/the-rabbit-hole-tech/eslint-config#readme",
  "bugs": {
    "url": "https://github.com/the-rabbit-hole-tech/eslint-config/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/the-rabbit-hole-tech/eslint-config.git"
  },
  "license": "MIT",
  "author": "Shane A. Froebel",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./lib/esm/index.d.mts",
        "default": "./lib/esm/index.mjs"
      },
      "require": {
        "types": "./lib/cjs/index.d.cts",
        "default": "./lib/cjs/index.cjs"
      }
    }
  },
  "main": "./lib/cjs/index.cjs",
  "module": "./lib/esm/index.mjs",
  "types": "./lib/esm/index.d.mts",
  "files": [
    "lib/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "build:local": "tsdown && eslint --fix && npm run pack",
    "lint": "eslint | snazzy",
    "lint:fix": "eslint --fix | snazzy",
    "lint:npm": "npmPkgJsonLint .",
    "lint:package": "npx sort-package-json",
    "pack": "npm pack",
    "prepare": "husky || true",
    "test": "vitest run",
    "test:coverage": "vitest --coverage",
    "test:watch": "vitest",
    "typedoc": "typedoc",
    "typedoc:watch": "typedoc -watch",
    "update": "npx npm-check-updates -u --peer && npm install --legacy-peer-deps"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-sort-class-members": "^1.22.1",
    "eslint-plugin-storybook": "^10.3.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^64.0.0",
    "typescript-eslint": "^8.59.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.2",
    "@commitlint/config-conventional": "^20.5.0",
    "@shipgirl/typedoc-plugin-versions": "^0.3.2",
    "@types/eslint-plugin-jsx-a11y": "^6.10.1",
    "@types/eslint-plugin-tailwindcss": "^3.17.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "npm": "^11.13.0",
    "npm-package-json-lint": "^10.3.0",
    "npm-package-json-lint-config-default": "^9.0.1",
    "prettier": "3.8.3",
    "snazzy": "^9.0.0",
    "sort-package-json": "^3.6.1",
    "storybook": "^10.3.5",
    "tsdown": "^0.21.10",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "eslint": "^9.39.4 || ^10.0.0",
    "prettier": "^3.8.3"
  },
  "packageManager": "npm@11.13.0"
}
